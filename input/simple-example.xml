<?xml version="1.0" ?>
<set prefix="combinatorial_">
    <series depth="1" end="0" interval="720" margin="6" name="SYNNOTCH_THRESHOLD_0_4" radius="34" start="0" ticks="10080">
        <patch>
            <patch.parameter id="GEOMETRY" value="hex"/>
            <patch.parameter id="INITIALIZATION" value="random"/>
        </patch>
        <agents>
            <populations>
                <population class="healthy" id="H1" init="60%">
                    <population.process id="METABOLISM" version="complex"/>
                    <population.process id="SIGNALING" version="complex"/>
                    <population.parameter id="CAR_ANTIGENS" value="0"/>
                    <population.parameter id="SYNNOTCH_ANTIGENS" value="0"/>
                    <population.parameter id="MAX_DENSITY" value="1"/>
                </population>
                <population class="healthy" id="H2" init="40%">
                    <population.process id="METABOLISM" version="complex"/>
                    <population.process id="SIGNALING" version="complex"/>
                    <population.parameter id="CAR_ANTIGENS" value="1000"/>
                    <population.parameter id="SYNNOTCH_ANTIGENS" value="0"/>
                    <population.parameter id="MAX_DENSITY" value="1"/>
                </population>
                <population class="cancer_stem" id="HIGH_DENSITY" init="200">
                    <population.process id="METABOLISM" version="complex"/>
                    <population.process id="SIGNALING" version="complex"/>
                    <population.parameter id="CAR_ANTIGENS" value="1000"/>
                    <population.parameter id="SYNNOTCH_ANTIGENS" value="10000000"/>
                    <population.parameter id="COMPRESSION_TOLERANCE" value="4.35"/>
                    <population.parameter id="METABOLIC_PREFERENCE" scale="1.5"/>
                    <population.parameter id="MIGRATORY_THRESHOLD" scale="0.5"/>
                </population>
                <population class="cancer_stem" id="LOW_DENSITY" init="200">
                    <population.process id="METABOLISM" version="complex"/>
                    <population.process id="SIGNALING" version="complex"/>
                    <population.parameter id="CAR_ANTIGENS" value="1000"/>
                    <population.parameter id="SYNNOTCH_ANTIGENS" value="630957"/>
                    <population.parameter id="COMPRESSION_TOLERANCE" value="4.35"/>
                    <population.parameter id="METABOLIC_PREFERENCE" scale="1.5"/>
                    <population.parameter id="MIGRATORY_THRESHOLD" scale="0.5"/>
                </population>
            </populations>
        </agents>
        <environments>
            <layers>
                <layer id="GLUCOSE">
                    <layer.parameter id="INITIAL_CONCENTRATION" value="0.005"/>
                    <layer.parameter id="DIFFUSIVITY" operation="diffuser" value="39.0"/>
                    <layer.parameter description="equal to 5 umol/cm^3" id="CONCENTRATION" operation="generator" units="fmol/um^3" value="0.005"/>
                    <layer.operation id="GENERATOR"/>
                    <layer.operation id="DIFFUSER"/>
                </layer>
                <layer id="OXYGEN">
                    <layer.parameter id="INITIAL_CONCENTRATION" value="100"/>
                    <layer.parameter id="DIFFUSIVITY" operation="diffuser" value="2000.0"/>
                    <layer.parameter id="CONCENTRATION" operation="generator" units="mmHg" value="100"/>
                    <layer.operation id="DIFFUSER"/>
                    <layer.operation id="GENERATOR"/>
                </layer>
                <layer id="TGFA">
                    <layer.parameter id="INITIAL_CONCENTRATION" value="150"/>
                    <layer.parameter id="DIFFUSIVITY" operation="diffuser" value="51.8"/>
                    <layer.operation id="DIFFUSER"/>
                </layer>
                <layer id="IL-2">
                    <layer.parameter id="INITIAL_CONCENTRATION" value="0"/>
                    <layer.parameter id="DIFFUSIVITY" operation="diffuser" value="10.0"/>
                    <layer.operation id="DIFFUSER"/>
                </layer>
            </layers>
            <components>
                <component class="source_sites" id="SITES">
                    <component.register id="GLUCOSE"/>
                    <component.register id="OXYGEN"/>
                </component>
            </components>
        </environments>
    </series>
</set>
