<set prefix="2025-04-21">
    <series name="fly-stem-mudmut-volume" start="2" end="2"
            ds=".3" margin="0" height="1" length="502" width="502"
            dt=".083" ticks="576" interval="4">
        <potts>
            <potts.term id="volume" />
            <potts.term id="adhesion" />
            <potts.term id="surface" />
            <potts.parameter term="surface" id="LAMBDA" value=".8" target='fly-stem-wt'/>
            <potts.parameter term="surface" id="LAMBDA" value=".4" target='fly-gmc'/>
            <potts.parameter term="adhesion" id="ADHESION" value="100" target="fly-neuron:*"/>
            <potts.parameter term="adhesion" id="ADHESION" value="100" target="fly-gmc:*"/>
            <potts.parameter term="adhesion" id="ADHESION" value="100" target="fly-stem-wt:*"/>
        </potts>
        <agents>
            <populations>
                <population id="fly-stem-wt" class="fly-stem-wt" init="1" >
                    <population.link id="fly-gmc" weight="1"/>
                    <population.parameter id="proliferation/SIZE_TARGET" value="1.2" />
                    <population.parameter id="CRITICAL_VOLUME" value="52" units="um^3" conversion="DS^-3" />
                    <population.parameter id="proliferation/CELL_GROWTH_RATE" value="35" units="um^3/hour" conversion="DS^-3DT"/>
                    <population.parameter id="proliferation/BASAL_APOPTOSIS_RATE" value="0"/>
                    <population.parameter id="proliferation/RATE_G1" value="12"/>
                    <population.parameter id="proliferation/RATE_S" value="20"/>
                    <population.parameter id="proliferation/RATE_G2" value="40"/>
                    <population.parameter id="proliferation/RATE_M" value="120"/>
                    <population.parameter id="proliferation/STEPS_G1" value="9"/>
                    <population.parameter id="proliferation/STEPS_S" value="9"/>
                    <population.parameter id="proliferation/STEPS_G2" value="9"/>
                    <population.parameter id="proliferation/STEPS_M" value="9"/>
                    <population.parameter id="proliferation/DIV_ROTATION_DISTRIBUTION" value="NORMAL(MU=0,SIGMA=30)" />
                    <population.parameter id="proliferation/DIFFERENTIATION_RULESET" value="volume" />
                    <!-- <population.parameter id="proliferation/DIFFERENTIATION_RULESET" value="location" /> -->
                    <!-- <population.parameter id="proliferation/DIFFERENTIATION_RULESET_EQUALITY_RANGE" value="10" /> -->
                    <population.parameter id="proliferation/DIFFERENTIATION_RULESET_EQUALITY_RANGE" value="386" />
                    <population.parameter id="proliferation/APICAL_AXIS_RULESET" value="rotation" />
                    <!-- <population.parameter id="proliferation/APICAL_AXIS_ROTATION_DISTRIBUTION" value="UNIFORM(MIN=0,MAX=360)" /> -->
                    <population.parameter id="proliferation/APICAL_AXIS_ROTATION_DISTRIBUTION" value="NORMAL(MU=0,SIGMA=30)" />
                    <population.parameter id="proliferation/DYNAMIC_GROWTH_RATE_VOLUME" value="0" />
                    <!-- <population.parameter id="proliferation/GROWTH_RATE_MULTIPLIER" value = ".1" /> -->
                    <population.parameter id="proliferation/VOLUME_BASED_CRITICAL_VOLUME" value="1" />
                    <population.parameter id="proliferation/VOLUME_BASED_CRITICAL_VOLUME_MULTIPLIER" value="1" />
                </population>
                <population id="fly-gmc" class="fly-gmc" init="0">
                    <population.link id="fly-neuron" weight="1"/>
                    <population.parameter id="proliferation/BASAL_APOPTOSIS_RATE" value="0"/>
                    <population.parameter id="proliferation/CELL_GROWTH_RATE" value="1.22" units="um^2/hour" conversion="DS^-2.DT"/>
                    <population.parameter id="proliferation/STEPS_G1" value="9"/>
                    <population.parameter id="proliferation/STEPS_S" value="9"/>
                    <population.parameter id="proliferation/STEPS_G2" value="9"/>
                    <population.parameter id="proliferation/STEPS_M" value="9"/>
                    <population.parameter id="proliferation/RATE_G1" value="2"/>
                    <population.parameter id="proliferation/RATE_S" value=".33"/>
                    <population.parameter id="proliferation/RATE_G2" value="6.67"/>
                    <population.parameter id="proliferation/RATE_M" value="20"/>

                </population>
                <population id="fly-neuron" class="fly-neuron" init="0">
                <population.parameter id="proliferation/CELL_GROWTH_RATE" value="0"/>
                <population.parameter id="proliferation/BASAL_APOPTOSIS_RATE" value="0"/>
                </population>
            </populations>
        </agents>
    </series>
</set>