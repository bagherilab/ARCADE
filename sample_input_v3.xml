<set prefix="test_">
    <series name="cycle" start="0" end="10" ticks="10080" interval="10080" radius="10" margin="2" depth="1" >
        <patch>
            <patch.parameter id="GEOMETRY" value="hex" />
        </patch>
        <agents>
            <populations>
                <population id="cancerous" init="1" class="cancer">
                    <population.parameter id="CELL_VOLUME" value="NORMAL(MU=2250,SIGMA=200)" />
                    <population.parameter id="APOPTOSIS_AGE" value="NORMAL(MU=120960,SIGMA=10080)" />
                    <population.parameter id="NECROTIC_FRACTION" value="0.5" />
                    <population.parameter id="ACCURACY" value="0.8" />
                    <population.parameter id="AFFINITY" value="0.5" />
                    <population.parameter id="COMPRESSION_TOLERANCE" value="4.35" />

                    <population.parameter id="CELL_AGE" value="UNIFORM(MIN=0,MAX=120960)" />
                    <population.process id="METABOLISM" version="complex" />
                    <population.process id="SIGNALING" version="complex"  />
                    <population.parameter id="proliferation/SYNTHESIS_DURATION" value="637" />
                </population>
                <population id="healthy" init="0" class="healthy">
                    <population.process id="METABOLISM" version="complex" />
                    <population.process id="SIGNALING" version="complex"  />
                    <population.parameter id="CELL_VOLUME" value="NORMAL(MU=2250,SIGMA=100)" />
                    <population.parameter id="COMPRESSION_TOLERANCE" value="0.0" />
                    <population.parameter id="NECROTIC_FRACTION" value="0.5" />
                    <population.parameter id="proliferation/SYNTHESIS_DURATION" value="637" />
                    <population.parameter id="metabolism/CONSTANT_VOLUME_GROWTH_RATE" value="2.819" />
                </population>
            </populations>
        </agents>
        <environments>
            <layers>
               <layer id="GLUCOSE">
                    <layer.parameter id="INITIAL_CONCENTRATION" value="0.005" />
                    <layer.parameter id="DIFFUSIVITY" operation="diffuser" value="39.0" />
                    <layer.parameter id="CONCENTRATION" operation="generator" value="0.005" units="fmol/um^3" description="equal to 5 umol/cm^3" />
                    <layer.operation id="GENERATOR" />
                    <layer.operation id="DIFFUSER" />
                </layer>
                <layer id="OXYGEN">
                    <layer.parameter id="INITIAL_CONCENTRATION" value="100" />
                    <layer.parameter id="DIFFUSIVITY" operation="diffuser" value="2000.0" />
                    <layer.parameter id="CONCENTRATION" operation="generator" value="100" units="mmHg" />
                    <layer.operation id="DIFFUSER" />
                    <layer.operation id="GENERATOR" />
                </layer>
                <layer id="TGFA">
                    <layer.parameter id="INITIAL_CONCENTRATION" value="150" />
                    <layer.parameter id="DIFFUSIVITY" operation="diffuser" value="51.8" />
                    <layer.operation id="DIFFUSER" />
                </layer>
            </layers>
            <components>
                <component id="SITES" class="source_sites">
                    <component.register id="GLUCOSE" />
                    <component.register id="OXYGEN" />
                </component>
            </components>
        </environments>
    </series>
</set>
